# ── outbound/.env ─────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# PostgreSQL
PGHOST=localhost
PGPORT=5432
PGDATABASE=flamingo
PGUSER=flamingo
PGPASSWORD=your_db_password

# Dashboard login credentials
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change_this_password

# Auth token signing secret — generate with: openssl rand -hex 32
AUTH_SECRET=generate_a_strong_random_secret_here

# Meta WhatsApp Cloud API
META_PHONE_NUMBER_ID=your_phone_number_id
META_ACCESS_TOKEN=your_access_token
META_API_VERSION=v19.0

# MocDoc HMS
MOCDOC_BASE_URL=https://mocdoc.com
MOCDOC_ENTITY_KEY=flamingo-healthcare-centre
MOCDOC_ACCESS_KEY=your_mocdoc_access_key
MOCDOC_SECRET=your_mocdoc_base64_secret
MOCDOC_POLL_INTERVAL_MS=30000

# Public URL of this service (used to build the Exotel StatusCallback URL —
# without it, outbound click-to-call won't capture completion status or
# recordings, since Exotel has nowhere to send the webhook)
PUBLIC_BASE_URL=https://your-outbound-service.up.railway.app

# Exotel (inbound webhook needs no credentials; these are for outbound
# click-to-call from the Leads page)
EXOTEL_SID=your_exotel_account_sid
EXOTEL_API_KEY=your_exotel_api_key
EXOTEL_API_TOKEN=your_exotel_api_token
EXOTEL_SUBDOMAIN=api.exotel.com
EXOTEL_CALLER_ID=your_exophone_number
EXOTEL_AGENT_NUMBER=default_agent_mobile_number
