# ── outbound/.env ─────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# PostgreSQL
PGHOST=localhost
PGPORT=5432
PGDATABASE=flamingo
PGUSER=flamingo
PGPASSWORD=your_db_password

# Meta WhatsApp Cloud API
META_PHONE_NUMBER_ID=your_phone_number_id
META_ACCESS_TOKEN=your_access_token
META_API_VERSION=v19.0

# MocDoc HMS
MOCDOC_BASE_URL=https://mocdoc.com
MOCDOC_ENTITY_KEY=flamingo-healthcare-centre
MOCDOC_ACCESS_KEY=your_mocdoc_access_key
MOCDOC_SECRET=your_mocdoc_base64_secret
MOCDOC_POLL_INTERVAL_MS=30000

# ── api/.env ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://flamingo:your_db_password@localhost:5432/flamingo
ENVIRONMENT=production
DEBUG=false

# JWT — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=generate_a_strong_random_secret_here

# Dashboard login credentials
# To hash password: python3 -c "from passlib.context import CryptContext; print(CryptContext(['bcrypt']).hash('yourpassword'))"
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme   # replace with bcrypt hash in production
